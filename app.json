{
  "expo": {
    "name": "BusTrack",
    "slug": "bustrack-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android"
    ],
    "newArchEnabled": false,
    "extra": {
      "eas": {
        "projectId": "71eb5550-b63b-4847-acbf-ad7f737241d5"
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "BusTrack needs your location to track the school bus route for parents."
        }
      ]
    ],
    "android": {
      "package": "com.kherasam18.bustrack",
      "googleServicesFile": "./google-services.json",
      "usesCleartextTraffic": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "owner": "khrsam02"
  }
}
