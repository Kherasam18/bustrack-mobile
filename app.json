{
  "expo": {
    "name": "BusTrack",
    "slug": "bustrack-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android"
    ],
    "newArchEnabled": false,
    "extra": {
      "eas": {
        "projectId": "865c02a9-f842-4c10-bce0-f0ef318bbbd6"
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "BusTrack needs your location to track the school bus route for parents."
        }
      ]
    ],
    "android": {
      "package": "com.kherasam18.bustrack",
      "googleServicesFile": "./google-services.json",
      "usesCleartextTraffic": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "RECEIVE_BOOT_COMPLETED"
      ]
    }
  }
}